reet = individualArrayItem.address[0].street + dt","    individualArrayItem.address[0].locality.code = String(new Date().getTime())","    individualArrayItem.fatherName = \"test_\" + Math.floor(Math.random() * 1000000)","    if(individualArrayItem.gender == \"FEMALE\")","        individualArrayItem.husbandName = \"Husband Name\"","    else","        individualArrayItem.husbandName = null","","    individualArrayItem.identifiers = []","    var identifierElem = {}","    identifierElem.identifierType = identifierTypes[Math.floor(Math.random() * identifierTypes.length)]","    identifierElem.identifierId = Math.floor((Math.random() * (999999999999 - 100000000000 + 1)) + 100000000000)","    individualArrayItem.identifiers.push(identifierElem)","","    individualArrayItem.skills = []","    var skillElem = {}","    skillElem.type =  skillTypes[Math.floor(Math.random() * skillTypes.length)]","    skillElem.level = skillLevels[Math.floor(Math.random() * skillLevels.length)]","    skillElem.experience = skillExperiences[Math.floor(Math.random() * skillExperiences.length)]","    individualArrayItem.skills.push(skillElem)","","    individualArrayItem.photo = dt","    individualArrayItem.additionalFields = additionalFields","    individualArrayItem.rowVersion = 1","","    individualArray.push(individualArrayItem)","}","pm.environment.set(\"individualArray\", JSON.stringify(individualArray))","","console.log('clientReferenceId I1:', pm.variables.get('uuid'));","console.log('clientReferenceId I2:', pm.variables.get('uuid2'));","","",""],"type":"text/javascript","packages":{},"requests":{},"id":"6b36d591-cc35-46ef-8e80-ef8c18974c1d"}},{"listen":"test","script":{"exec":["// {","//     \"RequestInfo\": {","//         \"authToken\": \"{{authToken}}\"","//     },","//     \"Individuals\": {{individualArray}}","// }","","console.log(\"uuid2  \" + pm.environment.get(\"uuid2\"));","console.log(\"uuid3  \" + pm.environment.get(\"uuid3\"));","console.log(\"uuid4  \" + pm.environment.get(\"uu