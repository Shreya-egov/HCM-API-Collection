1440-ca5da3d3-c81c-4b6f-ab0c-784559a2af9d"},{"name":"staff enroll - APPROVER","id":"c000fa42-24ef-4822-b211-2bbe50a8587c","protocolProfileBehavior":{"disableBodyPruning":true},"request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n    \"RequestInfo\": {\n        \"apiId\": \"mukta-services\",\n        \"ver\": null,\n        \"ts\": null,\n        \"action\": null,\n        \"did\": null,\n        \"key\": null,\n        \"msgId\": \"Enroll the user to register\",\n        \"authToken\": \"{{authToken}}\"\n    },\n    \"staff\": [\n        {\n            \"registerId\": \"{{registerDistrictId}}\",\n            \"userId\": \"{{PSUserUuid}}\",\n            \"staffType\": \"APPROVER\",\n            \"tenantId\": \"{{tenantId}}\"\n        }\n    ]\n}","options":{"raw":{"language":"json"}}},"url":{"raw":"{{URL}}/{{attendance}}/staff/v1/_create","host":["{{URL}}"],"path":["{{attendance}}","staff","v1","_create"]},"description":"Generated from cURL: curl --location 'https://unified-qa.digit.org/health-attendance/staff/v1/_create' \\\n--header 'Content-Type: application/json' \\\n--data '{\n   \"RequestInfo\":{\n      \"apiId\":\"mukta-services\",\n      \"ver\":null,\n      \"ts\":null,\n      \"action\":null,\n      \"did\":null,\n      \"key\":null,\n      \"msgId\":\"Enroll the user to register\",\n      \"authToken\": \"2efa4b03-fd89-4825-9cb1-ab53eae59bc1\"\n   },\n   \"staff\":[\n      {\n         \"registerId\": \"a28875ca-f05f-409b-ab04-711263df0457\",\n         \"userId\":\"72442383-4433-495c-bd30-1bc285788db6\", \n         \"staffType\": \"APPROVER\", \n         \"tenantId\":\"mz\"\n      }\n   ]\n}'"},"response":[],"createdAt":"2026-02-27T12:20:15.000Z","updatedAt":"2026-02-27T12:20:15.000Z","uid":"29681440-c000fa42-24ef-4822-b211-2bbe50a8587c"},{"name":"HRMS attendee CS","event":[{"listen":"test","script":{"exec":["let jsonData = pm.response.json();","pm.environment.set(\"CSUserServiceUuid\", jsonData.Employees[0].user.userServiceUuid);","pm.environment.set(\"CSUserUuid\", jsonData.Employees[0].user.uuid);","","const baseUrl = pm.environment.get(\"URL\");","// Define the POST request","const request1 = {","    url: baseUrl + \"/project/staff/v1/_create\",","    method: 'POST',","    header: {","        'Content-Type': 'application/json',","    },","    body: {","        mode: 'raw',","        raw: JSON.stringify({","            \"RequestInfo\": {","                \"authToken\": pm.environment.get(\"authToken\")","            },","            \"ProjectStaff\": {","                    \"tenantId\": pm.environment.get(\"tenantId\"),","                    // \"userId\": \"{{staffUserServiceUuid}}\", //userserviceID","                    \"userId\": pm.environment.get(\"CSUserServiceUuid\"), //userserviceID","                    // \"userId\": \"a85cc48e-8023-4575-bb8e-756b2bc98ec6\",","                    // \"projectId\": \"{{individualProjectId}}\",","                    \"projectId\": pm.environment.get(\"projectIdCountry\"),","                    // \"projectId\": pm.environment.get(\"projectIdProvince\"),","                    \"startDate\": pm.environment.get(\"projectStartDate\"),","                    \"endDate\": pm.environment.get(\"projectEndDate\"),","                    \"channel\": \"testing for HCM multi round mobile app\",","                    \"rowVersion\": 1,","                    \"additionalFields\": {","                        \"schema\": \"registration\",","                        \"version\": 1,","                        \"fields\": [","                            {","                                \"key\": \"key\",","                                \"value\": \"value\"","                            }","                        ]","                    }","                }","        })","    }","};","","// Send the request","pm.sendRequest(request1, function (err, res) {","    // Check for errors","    if (err) {","        console.error('Request failed:', err);","        return;","    }","","    // Log the response for debugging","    console.log('Response:', res.json());","","    // Assertions on the response","    pm.test('Status code is 202', function () {","        pm.expect(res.code).to.eql(202);","    });","});","",""],"type":"text/javascript","packages":{},"requests":{},"id":"529584c4-a712-4cb1-b3fc-d3a027325076"}},{"listen":"prerequest","script":{"exec":["// Generate a random name","const firstNames = [","    \"John\",","    \"Jane\",","    \"Michael\",","    \"Emily\",","    \"David\",","    \"Sarah\"","];","const lastNames = [","    \"Smith\",","    \"Johnson\",","    \"Williams\",","    \"Brown\",","    \"Jones\",","    \"Davis\"","];","","// Function to generate a random individual name","function generateRandomName() {","    const firstName = firstNames[Math.floor(Math.random() * firstNames.length)];","    const lastName = lastNames[Math.floor(Math.random() * lastNames.length)];","","    // Return the full name and parts separately for use elsewhere","    return { firstName, lastName, fullName: `${firstName} ${lastName}` };","}","","// Generate random names","const { firstName, lastName, fullName: randomFullName } = generateRandomName();","","// Generate a random 10-digit number","const randomNumber = Math.floor(1000000000 + Math.random() * 9000000000);","","// Generate a random email address","const randomEmail = `${firstName.toLowerCase()}${lastName.toLowerCase()}@example.com`;","","const randomThreeDigitNumber = Math.floor(100 + Math.random() * 900);","","// Set these variables in the environment or collection scope","pm.environment.set(\"randomName6\", randomFullName);","pm.environment.set(\"randomNumber6\", randomNumber);","pm.environment.set(\"randomEmail6\", randomEmail);","pm.environment.set(\"randomUserName6\",randomThreeDigitNumber);","","// Log the generated values for debugging","console.log(\"Generated Name: \", randomFullName);","console.log(\"Generated Number: \", randomNumber);","console.log(\"Generated Email: \", randomEmail);"],"type":"text/javascript","packages":{},"requests":{},"id":"32ffa926-62b1-467e-b2df-89589a6bddcd"}}],"id":"8d695070-9faa-43d6-8bee-3d4fe70c7a67","protocolProfileBehavior":{"disableBodyPruning":true},"request":{"method":"POST","header":[{"key":"authority","value":"unified-dev.digit.org"},{"key":"accept","value":"application/json, text/plain, */*"},{"key":"accept-language","value":"en-GB,en-US;q=0.9,en;q=0.8"},{"key":"content-type","value":"application/json;charset=UTF-8"},{"key":"cookie","value":"_ga_H9YC8FEN6F=GS1.1.1704892149.2.1.1704892416.60.0.0; _ga_0JZG96DZSM=GS1.1.1704952026.9.1.1704953656.25.0.0; _ga_V2CPZCVTXQ=GS1.1.1705472749.3.0.1705472749.0.0.0; _ga=GA1.1.1573992852.1702469055; _ga_XBQP06FR8V=GS1.1.1706697152.1.1.1706698636.60.0.0; __cuid=dff1142b62e34f53b35747a950dff6f8; amp_fef1e8=1dd32260-1592-4a18-9ace-531494eedb5dR...1hlfh7smq.1hlfilmgt.3b.8.3j"},{"key":"origin","value":"https://unified-dev.digit.org"},{"key":"priority","value":"u=1, i"},{"key":"referer","value":"https://unified-dev.digit.org/health-ui/employee/hrms/response"},{"key":"sec-ch-ua","value":"\"Not_A Brand\";v=\"8\", \"Chromium\";v=\"120\", \"Google Chrome\";v=\"120\""},{"key":"sec-ch-ua-mobile","value":"?0"},{"key":"sec-ch-ua-platform","value":"\"Linux\""},{"key":"sec-fetch-dest","value":"empty"},{"key":"sec-fetch-mode","value":"cors"},{"key":"sec-fetch-site","value":"same-origin"},{"key":"user-agent","value":"Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"}],"body":{"mode":"raw","raw":"{\n    \"Employees\": [\n        {\n            \"tenantId\": \"{{tenantId}}\",\n            \"employeeStatus\": \"EMPLOYED\",\n            \"assignments\": [\n                {\n                    \"fromDate\": {{projectStartDate}},\n                    \"isCurrentAssignment\": true,\n                    \"designation\": \"DESIG_01\",\n                    \"department\": \"eGov\"\n        