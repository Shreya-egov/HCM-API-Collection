gin"},{"key":"user-agent","value":"Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/138.0.0.0 Safari/537.36"}],"body":{"mode":"raw","raw":"{\n    \"CampaignDetails\": {\n        // \"id\": \"0576d413-fb7d-439e-bec0-e05d6d932c16\",\n        \"tenantId\": \"mz\",\n        \"action\": \"draft\",\n        // \"campaignNumber\": \"CMP-2025-11-04-000026\",\n        \"isActive\": true,\n        \"parentId\": null,\n        \"campaignName\": \"{{campaignName}}\",\n        \"projectType\": \"{{projectType}}\",\n        \"hierarchyType\": \"{{hierarchyType}}\",\n        \"boundaryCode\": \"{{hierarchyTypeCode}}\",\n        // \"projectId\": \"e8abc9a2-6d2e-4d28-a732-f250c51e09d6\",\n        \"startDate\": 1862387200000,\n        \"endDate\": 1864872999000,\n        \"additionalDetails\": {\n       \n            \"beneficiaryType\": \"HOUSEHOLD\"\n        },\n        // \"resources\":   [  {\n        //             \"type\": \"unified-console-resources\",\n        //             \"filename\": \"Codelivery_october_2025-01_Facility Template.xlsx\",\n        //             \"filestoreId\": \"9a7c9b7a-63ac-4c9d-9970-41315ac749e1\"\n        //         }],\n               \"isUnifiedCampaign\": true,\n        \"boundaries\": [\n            {\n                \"code\": \"{{hierarchyTypeCode}}\",\n                \"name\": \"{{hierarchyTypeName}}\",\n                \"type\": \"{{hierarchyLevel}}\",\n                \"isRoot\": true,\n                \"includeAllChildren\": true\n            }\n        ],\n        \"deliveryRules\": [\n                {\n                    \"id\": \"Bednet\",\n                    \"code\": \"Bednet\",\n                    \"name\": \"Bednet\",\n                    \"group\": \"MALARIA\",\n                    \"cycles\": [\n                        {\n                            \"id\": 1,\n                            \"startDate\": 1862387200000,\n        \"endDate\": 1864872999000,\n                            \"deliverie